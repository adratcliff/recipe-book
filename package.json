{
  "name": "recipe-book",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:federation": "concurrently \"vite build --watch --mode development\" \"vite preview\"",
    "serve": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vuetify": "^3.11.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.42.0",
    "eslint-plugin-vue": "~10.7.0",
    "globals": "^17.2.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.42.0",
    "prettier": "3.8.1",
    "sass-embedded": "^1.97.3",
    "vite": "beta",
    "vite-plugin-vue-devtools": "^8.0.5",
    "vite-plugin-vuetify": "^2.1.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
